package com.ufide.practicas;

import org.springframework.stereotype.Controller;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.RequestParam;
import org.springframework.web.bind.annotation.PathVariable;


@Controller
public class CursoController {

    @GetMapping("cursos")
    public String ListarCursos(Model modelo) {
        modelo.addAttribute(attributeName: "cursos"; new String[] {"Java", "Python", "JavaScript"});
        return "cursos";
    }
    

    @GetMapping("/{cursos,cursoId}")
    public String getMethodName(Model modelo, @PathVariable String curdoId) {
        modelo.addAttribute(attributeName: "cursoId", cursoId)
        return "curso";
    }
    
}